{
  "name": "@jasara/azlabels-ts-generator",
  "version": "0.1.1",
  "description": "TypeScript ZPL label generator for Amazon FNSKU/barcode labels, verified byte-for-byte against a reference implementation via a shared conformance corpus.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasara/azlabels-ts-generator.git"
  },
  "homepage": "https://github.com/jasara/azlabels-ts-generator#readme",
  "bugs": "https://github.com/jasara/azlabels-ts-generator/issues",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zpl",
    "zebra",
    "label",
    "fnsku",
    "barcode",
    "amazon",
    "thermal-printer"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
