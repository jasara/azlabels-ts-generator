{
  "name": "@jasara/azlabels-ts-generator",
  "version": "0.0.0",
  "description": "TypeScript ZPL label generator for Amazon FNSKU/barcode labels — a faithful port of jasara/azlabels-api's ZPL logic, kept in lockstep via a shared conformance corpus.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zpl",
    "zebra",
    "label",
    "fnsku",
    "barcode",
    "amazon",
    "thermal-printer"
  ],
  "license": "UNLICENSED",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
